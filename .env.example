NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://jobs:jobs@localhost:5432/jobs
PG_POOL_MAX=10
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
JWT_SECRET=abc
JWT_EXPIRES_IN=24h
ADMIN_USER=admin
ADMIN_PASSWORD=admin
WORKER_CONCURRENCY=5
WORKER_IDLE_MS=50
LOCK_TTL_SEC=30
HEARTBEAT_INTERVAL_MS=5000
STALLED_RECOVERY_INTERVAL_MS=5000
DELAYED_PROMOTE_INTERVAL_MS=1000
MAX_RETRIES=3
BACKOFF_BASE_MS=1000
BACKOFF_MAX_MS=60000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOG_LEVEL=info
